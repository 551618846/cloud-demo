<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 从Spring环境读取应用名称，用于日志文件命名 -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="app"/>

    <!-- 引入公共日志模板 -->
    <include resource="template/logback-base.xml"/>

    <!-- 特定包的日志级别 -->
    <logger name="com.example.mygateway" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE_ALL"/>
        <appender-ref ref="ASYNC_FILE_ERROR"/>
    </logger>

    <logger name="org.springframework.cloud.gateway" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
<!--        <appender-ref ref="ASYNC_FILE_ALL"/>-->
<!--        <appender-ref ref="ASYNC_FILE_ERROR"/>-->
    </logger>

</configuration>
